# Hermes Coach — local development environment
# Copy to .env and fill in real values before running docker compose up.
# Never commit .env — it is in .gitignore.

# --- Required ---

# Discord bot token (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Your personal Discord user ID (enables admin access in local dev)
DISCORD_ALLOWED_USERS=your-discord-user-id

# opencode.ai API key
OPENCODE_GO_API_KEY=your-opencode-api-key

# --- Optional overrides ---

# Discord channel ID that responds without @mention (leave blank to require @mention everywhere)
# DISCORD_FREE_RESPONSE_CHANNELS=

# Discord role ID whose members can interact with the bot (leave blank to allow all)
# DISCORD_ALLOWED_ROLES=

# Override the model (default: deepseek-v4-pro)
# HERMES_INFERENCE_MODEL=deepseek-v4-pro
